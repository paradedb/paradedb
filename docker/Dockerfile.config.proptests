FROM scratch

# Antithesis "config image" for the property-tests workload: only the manifests
# this workflow needs are bundled, so the stressgres pod is not launched
# alongside it.
COPY docker/manifests/cnpg.yaml /manifests/
COPY docker/manifests/antithesis-paradedb.yaml /manifests/
COPY docker/manifests/antithesis-proptests.yaml /manifests/
