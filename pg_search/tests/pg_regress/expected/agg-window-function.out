-- Minimal repro: pdb.agg() as a window function fails with
--   "pdb.agg() must be handled by ParadeDB's custom scan"
-- The planner places a WindowAgg node above the Custom Scan,
-- so pg_search never intercepts the pdb.agg() call.
CREATE EXTENSION IF NOT EXISTS pg_search;
SET paradedb.enable_aggregate_custom_scan TO on;
DROP TABLE IF EXISTS items CASCADE;
CREATE TABLE items (
    id SERIAL PRIMARY KEY,
    description TEXT,
    category TEXT
);
INSERT INTO items (description, category) VALUES
    ('red shoes',    'footwear'),
    ('blue shoes',   'footwear'),
    ('green jacket', 'apparel'),
    ('red hat',      'apparel'),
    ('blue scarf',   'apparel');
CREATE INDEX items_idx ON items
USING bm25 (id, description, (category::pdb.literal))
WITH (key_field = 'id');
-- This works: pdb.agg() as a regular aggregate
SELECT pdb.agg('{"terms": {"field": "category"}}'::jsonb)
FROM items
WHERE id @@@ pdb.all();
                                                                        agg                                                                         
----------------------------------------------------------------------------------------------------------------------------------------------------
 {"buckets": [{"key": "apparel", "doc_count": 3}, {"key": "footwear", "doc_count": 2}], "sum_other_doc_count": 0, "doc_count_error_upper_bound": 0}
(1 row)

-- This fails: pdb.agg() OVER () without ORDER BY + LIMIT
SELECT
    id,
    description,
    pdb.agg('{"terms": {"field": "category"}}'::jsonb) OVER ()
FROM items
WHERE id @@@ pdb.all();
ERROR:  pdb.agg() window functions require a valid Top K query (ORDER BY and LIMIT) where all ORDER BY columns are indexed and sortable (fast fields). Ensure you are sorting by indexed columns of a single table with a BM25 index.
-- This works: pdb.agg() OVER () with ORDER BY indexed column + LIMIT
SELECT
    id,
    description,
    pdb.agg('{"terms": {"field": "category"}}'::jsonb) OVER ()
FROM items
WHERE id @@@ pdb.all()
ORDER BY id
LIMIT 3;
 id | description  |                                                                        agg                                                                         
----+--------------+----------------------------------------------------------------------------------------------------------------------------------------------------
  1 | red shoes    | {"buckets": [{"key": "apparel", "doc_count": 3}, {"key": "footwear", "doc_count": 2}], "sum_other_doc_count": 0, "doc_count_error_upper_bound": 0}
  2 | blue shoes   | {"buckets": [{"key": "apparel", "doc_count": 3}, {"key": "footwear", "doc_count": 2}], "sum_other_doc_count": 0, "doc_count_error_upper_bound": 0}
  3 | green jacket | {"buckets": [{"key": "apparel", "doc_count": 3}, {"key": "footwear", "doc_count": 2}], "sum_other_doc_count": 0, "doc_count_error_upper_bound": 0}
(3 rows)

-- This fails: pdb.agg() OVER () with ORDER BY pdb.score() + LIMIT
-- This is the most natural search pattern (top results by relevance + facets)
EXPLAIN (COSTS OFF, VERBOSE, TIMING OFF)
SELECT
    id,
    description,
    pdb.score(id) as score,
    pdb.agg('{"terms": {"field": "category"}}'::jsonb) OVER ()
FROM items
WHERE description @@@ pdb.all()
ORDER BY pdb.score(id) DESC
LIMIT 3;
                                                                                                                                   QUERY PLAN                                                                                                                                    
---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
 Limit
   Output: id, description, (pdb.score(id)), (pdb.window_agg('{"entries":[{"Aggregate":{"Custom":{"agg_json":{"terms":{"field":"category"}},"filter":null,"indexrelid":0,"mvcc_visibility":"Enabled"}}}],"groupby":{"grouping_columns":[]},"uses_our_operator":false}'::text))
   ->  Custom Scan (ParadeDB Base Scan) on public.items
         Output: id, description, pdb.score(id), pdb.window_agg('{"entries":[{"Aggregate":{"Custom":{"agg_json":{"terms":{"field":"category"}},"filter":null,"indexrelid":0,"mvcc_visibility":"Enabled"}}}],"groupby":{"grouping_columns":[]},"uses_our_operator":false}'::text)
         Table: items
         Index: items_idx
         Exec Method: TopKScanExecState
         Scores: true
            TopK Order By: pdb.score() desc
            TopK Limit: 3
         Tantivy Query: {"with_index":{"query":{"all":{"field":"description"}}}}
(11 rows)

SELECT
    id,
    description,
    pdb.score(id) as score,
    pdb.agg('{"terms": {"field": "category"}}'::jsonb) OVER ()
FROM items
WHERE description @@@ pdb.all()
ORDER BY pdb.score(id) DESC
LIMIT 3;
 id | description  | score |                                                                        agg                                                                         
----+--------------+-------+----------------------------------------------------------------------------------------------------------------------------------------------------
  1 | red shoes    |     1 | {"buckets": [{"key": "apparel", "doc_count": 3}, {"key": "footwear", "doc_count": 2}], "sum_other_doc_count": 0, "doc_count_error_upper_bound": 0}
  2 | blue shoes   |     1 | {"buckets": [{"key": "apparel", "doc_count": 3}, {"key": "footwear", "doc_count": 2}], "sum_other_doc_count": 0, "doc_count_error_upper_bound": 0}
  3 | green jacket |     1 | {"buckets": [{"key": "apparel", "doc_count": 3}, {"key": "footwear", "doc_count": 2}], "sum_other_doc_count": 0, "doc_count_error_upper_bound": 0}
(3 rows)

DROP TABLE items CASCADE;
