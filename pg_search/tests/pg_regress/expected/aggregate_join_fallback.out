-- =====================================================================
-- Negative tests: verify graceful fallback to Postgres native plans
-- for unsupported aggregate-on-join query patterns.
-- =====================================================================
CREATE EXTENSION IF NOT EXISTS pg_search;
SET paradedb.enable_aggregate_custom_scan TO on;
-- =====================================================================
-- Test Data Setup (3 tables for multi-table join tests)
-- =====================================================================
CREATE TABLE fb_products (
    id SERIAL PRIMARY KEY,
    description TEXT,
    category TEXT,
    price FLOAT
);
CREATE TABLE fb_tags (
    id SERIAL PRIMARY KEY,
    product_id INTEGER,
    tag_name TEXT
);
CREATE TABLE fb_reviews (
    id SERIAL PRIMARY KEY,
    product_id INTEGER,
    rating INTEGER
);
INSERT INTO fb_products (description, category, price) VALUES
    ('Laptop computer fast', 'Electronics', 999.99),
    ('Running shoes light', 'Sports', 89.99),
    ('Winter jacket warm', 'Clothing', 129.99);
INSERT INTO fb_tags (product_id, tag_name) VALUES
    (1, 'tech'), (2, 'fitness'), (3, 'outdoor');
INSERT INTO fb_reviews (product_id, rating) VALUES
    (1, 5), (1, 4), (2, 3), (3, 4);
CREATE INDEX fb_products_idx ON fb_products
USING bm25 (id, description, category, price)
WITH (
    key_field='id',
    text_fields='{"description": {}, "category": {"fast": true}}',
    numeric_fields='{"price": {"fast": true}}'
);
CREATE INDEX fb_tags_idx ON fb_tags
USING bm25 (id, product_id, tag_name)
WITH (
    key_field='id',
    numeric_fields='{"product_id": {"fast": true}}',
    text_fields='{"tag_name": {"fast": true}}'
);
CREATE INDEX fb_reviews_idx ON fb_reviews
USING bm25 (id, product_id, rating)
WITH (
    key_field='id',
    numeric_fields='{"product_id": {"fast": true}, "rating": {"fast": true}}'
);
-- =====================================================================
-- Test 1: 3-table join → should fall back to Postgres native
-- =====================================================================
EXPLAIN (FORMAT TEXT, COSTS OFF, TIMING OFF, VERBOSE)
SELECT COUNT(*)
FROM fb_products p
JOIN fb_tags t ON p.id = t.product_id
JOIN fb_reviews r ON p.id = r.product_id
WHERE p.description @@@ 'laptop';
WARNING:  Aggregate Scan (DataFusion) not used: only 2-table joins are currently supported (table: join)
                                                                                  QUERY PLAN                                                                                   
-------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
 Aggregate
   Output: count(*)
   ->  Nested Loop
         Join Filter: (p.id = t.product_id)
         ->  Hash Join
               Output: p.id, r.product_id
               Inner Unique: true
               Hash Cond: (r.product_id = p.id)
               ->  Seq Scan on public.fb_reviews r
                     Output: r.id, r.product_id, r.rating
               ->  Hash
                     Output: p.id
                     ->  Custom Scan (ParadeDB Base Scan) on public.fb_products p
                           Output: p.id
                           Table: fb_products
                           Index: fb_products_idx
                           Exec Method: ColumnarExecState
                           Fast Fields: id
                           Scores: false
                           Tantivy Query: {"with_index":{"query":{"parse_with_field":{"field":"description","query_string":"laptop","lenient":null,"conjunction_mode":null}}}}
         ->  Seq Scan on public.fb_tags t
               Output: t.id, t.product_id, t.tag_name
(22 rows)

SELECT COUNT(*)
FROM fb_products p
JOIN fb_tags t ON p.id = t.product_id
JOIN fb_reviews r ON p.id = r.product_id
WHERE p.description @@@ 'laptop';
WARNING:  Aggregate Scan (DataFusion) not used: only 2-table joins are currently supported (table: join)
 count 
-------
     2
(1 row)

-- Test 1b: 3-table join with GROUP BY
SELECT p.category, COUNT(*), SUM(r.rating)
FROM fb_products p
JOIN fb_tags t ON p.id = t.product_id
JOIN fb_reviews r ON p.id = r.product_id
WHERE p.description @@@ 'laptop OR shoes OR jacket'
GROUP BY p.category
ORDER BY p.category;
WARNING:  Aggregate Scan (DataFusion) not used: only 2-table joins are currently supported (table: join)
  category   | count | sum 
-------------+-------+-----
 Clothing    |     1 |   4
 Electronics |     2 |   9
 Sports      |     1 |   3
(3 rows)

-- Test 1c: 3-table join parity — DataFusion vs Postgres native
SET paradedb.enable_aggregate_custom_scan TO off;
SELECT p.category, COUNT(*), SUM(r.rating)
FROM fb_products p
JOIN fb_tags t ON p.id = t.product_id
JOIN fb_reviews r ON p.id = r.product_id
WHERE p.description @@@ 'laptop OR shoes OR jacket'
GROUP BY p.category
ORDER BY p.category;
  category   | count | sum 
-------------+-------+-----
 Clothing    |     1 |   4
 Electronics |     2 |   9
 Sports      |     1 |   3
(3 rows)

SET paradedb.enable_aggregate_custom_scan TO on;
-- Test 1d: 3-table join with multiple aggregates
EXPLAIN (FORMAT TEXT, COSTS OFF, TIMING OFF, VERBOSE)
SELECT p.category, COUNT(*), SUM(r.rating), AVG(r.rating), MIN(r.rating), MAX(r.rating)
FROM fb_products p
JOIN fb_tags t ON p.id = t.product_id
JOIN fb_reviews r ON p.id = r.product_id
WHERE p.description @@@ 'laptop OR shoes OR jacket'
GROUP BY p.category;
WARNING:  Aggregate Scan (DataFusion) not used: only 2-table joins are currently supported (table: join)
                                                                                               QUERY PLAN                                                                                               
--------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
 GroupAggregate
   Output: p.category, count(*), sum(r.rating), avg(r.rating), min(r.rating), max(r.rating)
   Group Key: p.category
   ->  Sort
         Output: p.category, r.rating
         Sort Key: p.category
         ->  Nested Loop
               Output: p.category, r.rating
               Join Filter: (p.id = t.product_id)
               ->  Hash Join
                     Output: p.category, p.id, r.rating, r.product_id
                     Inner Unique: true
                     Hash Cond: (r.product_id = p.id)
                     ->  Seq Scan on public.fb_reviews r
                           Output: r.id, r.product_id, r.rating
                     ->  Hash
                           Output: p.category, p.id
                           ->  Custom Scan (ParadeDB Base Scan) on public.fb_products p
                                 Output: p.category, p.id
                                 Table: fb_products
                                 Index: fb_products_idx
                                 Exec Method: ColumnarExecState
                                 Fast Fields: category, id
                                 Scores: false
                                 Tantivy Query: {"with_index":{"query":{"parse_with_field":{"field":"description","query_string":"laptop OR shoes OR jacket","lenient":null,"conjunction_mode":null}}}}
               ->  Materialize
                     Output: t.product_id
                     ->  Seq Scan on public.fb_tags t
                           Output: t.product_id
(29 rows)

SELECT p.category, COUNT(*), SUM(r.rating), AVG(r.rating), MIN(r.rating), MAX(r.rating)
FROM fb_products p
JOIN fb_tags t ON p.id = t.product_id
JOIN fb_reviews r ON p.id = r.product_id
WHERE p.description @@@ 'laptop OR shoes OR jacket'
GROUP BY p.category
ORDER BY p.category;
WARNING:  Aggregate Scan (DataFusion) not used: only 2-table joins are currently supported (table: join)
  category   | count | sum |        avg         | min | max 
-------------+-------+-----+--------------------+-----+-----
 Clothing    |     1 |   4 | 4.0000000000000000 |   4 |   4
 Electronics |     2 |   9 | 4.5000000000000000 |   4 |   5
 Sports      |     1 |   3 | 3.0000000000000000 |   3 |   3
(3 rows)

-- Test 1e: 3-table star schema (tags and reviews both join to products)
SELECT COUNT(*)
FROM fb_products p
JOIN fb_tags t ON p.id = t.product_id
JOIN fb_reviews r ON p.id = r.product_id
WHERE p.description @@@ 'laptop';
WARNING:  Aggregate Scan (DataFusion) not used: only 2-table joins are currently supported (table: join)
 count 
-------
     2
(1 row)

-- Test 1f: 3-table chain join (products → tags → reviews via tag)
-- Note: fb_reviews doesn't have tag_id, so we join on product_id for both
-- This tests the equi-key injection at the correct join level
SELECT t.tag_name, COUNT(*), SUM(r.rating)
FROM fb_products p
JOIN fb_tags t ON p.id = t.product_id
JOIN fb_reviews r ON p.id = r.product_id
WHERE p.description @@@ 'laptop OR shoes OR jacket'
GROUP BY t.tag_name
ORDER BY t.tag_name;
WARNING:  Aggregate Scan (DataFusion) not used: only 2-table joins are currently supported (table: join)
 tag_name | count | sum 
----------+-------+-----
 fitness  |     1 |   3
 outdoor  |     1 |   4
 tech     |     2 |   9
(3 rows)

-- Test 1g: 3-table with LEFT JOIN → should use DataFusion backend
EXPLAIN (FORMAT TEXT, COSTS OFF, TIMING OFF)
SELECT p.category, COUNT(*), COUNT(r.rating)
FROM fb_products p
LEFT JOIN fb_tags t ON p.id = t.product_id
LEFT JOIN fb_reviews r ON p.id = r.product_id
WHERE p.description @@@ 'laptop OR shoes OR jacket'
GROUP BY p.category;
WARNING:  Aggregate Scan (DataFusion) not used: only 2-table joins are currently supported (table: join)
                                                                                               QUERY PLAN                                                                                               
--------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
 GroupAggregate
   Group Key: p.category
   ->  Sort
         Sort Key: p.category
         ->  Nested Loop Left Join
               Join Filter: (p.id = t.product_id)
               ->  Hash Right Join
                     Hash Cond: (r.product_id = p.id)
                     ->  Seq Scan on fb_reviews r
                     ->  Hash
                           ->  Custom Scan (ParadeDB Base Scan) on fb_products p
                                 Table: fb_products
                                 Index: fb_products_idx
                                 Exec Method: ColumnarExecState
                                 Fast Fields: category, id
                                 Scores: false
                                 Tantivy Query: {"with_index":{"query":{"parse_with_field":{"field":"description","query_string":"laptop OR shoes OR jacket","lenient":null,"conjunction_mode":null}}}}
               ->  Materialize
                     ->  Seq Scan on fb_tags t
(19 rows)

SELECT p.category, COUNT(*), COUNT(r.rating)
FROM fb_products p
LEFT JOIN fb_tags t ON p.id = t.product_id
LEFT JOIN fb_reviews r ON p.id = r.product_id
WHERE p.description @@@ 'laptop OR shoes OR jacket'
GROUP BY p.category
ORDER BY p.category;
WARNING:  Aggregate Scan (DataFusion) not used: only 2-table joins are currently supported (table: join)
  category   | count | count 
-------------+-------+-------
 Clothing    |     1 |     1
 Electronics |     2 |     2
 Sports      |     1 |     1
(3 rows)

-- =====================================================================
-- Test 2: CROSS JOIN → should fall back to Postgres native
-- =====================================================================
EXPLAIN (FORMAT TEXT, COSTS OFF, TIMING OFF)
SELECT COUNT(*)
FROM fb_products p
CROSS JOIN fb_tags t
WHERE p.description @@@ 'laptop';
WARNING:  Aggregate Scan (DataFusion) not used: CROSS JOINs are not supported (no equi-join keys) (table: join)
                                                                            QUERY PLAN                                                                             
-------------------------------------------------------------------------------------------------------------------------------------------------------------------
 Aggregate
   ->  Nested Loop
         ->  Custom Scan (ParadeDB Base Scan) on fb_products p
               Table: fb_products
               Index: fb_products_idx
               Exec Method: NormalScanExecState
               Scores: false
               Tantivy Query: {"with_index":{"query":{"parse_with_field":{"field":"description","query_string":"laptop","lenient":null,"conjunction_mode":null}}}}
         ->  Seq Scan on fb_tags t
(9 rows)

SELECT COUNT(*)
FROM fb_products p
CROSS JOIN fb_tags t
WHERE p.description @@@ 'laptop';
WARNING:  Aggregate Scan (DataFusion) not used: CROSS JOINs are not supported (no equi-join keys) (table: join)
 count 
-------
     3
(1 row)

-- =====================================================================
-- Test 3: HAVING clause → should now use DataFusion
-- =====================================================================
EXPLAIN (FORMAT TEXT, COSTS OFF, TIMING OFF, VERBOSE)
SELECT p.category, COUNT(*)
FROM fb_products p
JOIN fb_tags t ON p.id = t.product_id
WHERE p.description @@@ 'laptop OR shoes OR jacket'
GROUP BY p.category
HAVING COUNT(*) > 0;
                   QUERY PLAN                    
-------------------------------------------------
 Custom Scan (ParadeDB Aggregate Scan)
   Output: p.category, (count(*))
   Backend: DataFusion
   Indexes: fb_products_idx (p), fb_tags_idx (t)
   Group By: category
   Aggregates: COUNT(*)(*)
(6 rows)

SELECT p.category, COUNT(*)
FROM fb_products p
JOIN fb_tags t ON p.id = t.product_id
WHERE p.description @@@ 'laptop OR shoes OR jacket'
GROUP BY p.category
HAVING COUNT(*) > 0;
  category   | count 
-------------+-------
 Electronics |     1
 Sports      |     1
 Clothing    |     1
(3 rows)

-- Test 3b: HAVING parity — DataFusion vs Postgres native
SET paradedb.enable_aggregate_custom_scan TO off;
SELECT p.category, COUNT(*)
FROM fb_products p
JOIN fb_tags t ON p.id = t.product_id
WHERE p.description @@@ 'laptop OR shoes OR jacket'
GROUP BY p.category
HAVING COUNT(*) > 0
ORDER BY p.category;
  category   | count 
-------------+-------
 Clothing    |     1
 Electronics |     1
 Sports      |     1
(3 rows)

SET paradedb.enable_aggregate_custom_scan TO on;
SELECT p.category, COUNT(*)
FROM fb_products p
JOIN fb_tags t ON p.id = t.product_id
WHERE p.description @@@ 'laptop OR shoes OR jacket'
GROUP BY p.category
HAVING COUNT(*) > 0
ORDER BY p.category;
  category   | count 
-------------+-------
 Clothing    |     1
 Electronics |     1
 Sports      |     1
(3 rows)

-- =====================================================================
-- Clean up
-- =====================================================================
DROP TABLE fb_reviews;
DROP TABLE fb_tags;
DROP TABLE fb_products;
