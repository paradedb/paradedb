-------+---
 A     | 3
(1 row)

SET paradedb.enable_aggregate_custom_scan TO on;
DROP TABLE asa_n10_outer; DROP TABLE asa_n10_in1;
DROP TABLE asa_n10_in2; DROP TABLE asa_n10_in3;
