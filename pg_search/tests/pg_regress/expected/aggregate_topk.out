\i common/common_setup.sql
CREATE EXTENSION IF NOT EXISTS pg_search;
-- Disable parallel workers to avoid differences in plans
SET max_parallel_workers_per_gather = 0;
SET enable_indexscan to OFF;
SET paradedb.enable_columnar_exec = true;
CREATE EXTENSION IF NOT EXISTS pg_search;
SET paradedb.enable_aggregate_custom_scan TO on;
-- Create test table
CALL paradedb.create_bm25_test_table(
    schema_name => 'public',
    table_name => 'mock_items'
);
CREATE INDEX idx_mock_items ON mock_items
    USING bm25 (id, description, category, rating, in_stock)
    WITH (
        key_field='id',
        text_fields='{"description": {}, "category": {"fast": true}}',
        numeric_fields='{"rating": {"fast": true}}',
        boolean_fields='{"in_stock": {"fast": true}}'
    );
-- Use a broad query to match items across multiple categories
-- ================================================================
-- Test 1: ORDER BY COUNT(*) DESC LIMIT (TopK by doc count)
-- ================================================================
EXPLAIN (COSTS OFF, VERBOSE, TIMING OFF)
SELECT category, COUNT(*)
FROM mock_items
WHERE mock_items @@@ paradedb.all()
GROUP BY category
ORDER BY COUNT(*) DESC
LIMIT 3;
                     QUERY PLAN                     
----------------------------------------------------
 Limit
   Output: category, (count(*))
   ->  Sort
         Output: category, (count(*))
         Sort Key: (count(*)) DESC
         ->  Custom Scan (ParadeDB Aggregate Scan)
               Output: category, (count(*))
               Backend: DataFusion
               Indexes: idx_mock_items (mock_items)
               Group By: category
               Aggregates: COUNT(*)
(11 rows)

SELECT category, COUNT(*)
FROM mock_items
WHERE mock_items @@@ paradedb.all()
GROUP BY category
ORDER BY COUNT(*) DESC
LIMIT 3;
  category   | count 
-------------+-------
 Footwear    |     6
 Electronics |     5
 Photography |     4
(3 rows)

-- ================================================================
-- Test 2: ORDER BY SUM(field) DESC LIMIT — routed to DataFusion
-- Non-COUNT aggregate ordering is handled by DataFusion (not Tantivy)
-- for correct NULL semantics. Verify the routing works.
-- ================================================================
EXPLAIN (COSTS OFF, VERBOSE, TIMING OFF)
SELECT category, SUM(rating)
FROM mock_items
WHERE mock_items @@@ paradedb.all()
GROUP BY category
ORDER BY SUM(rating) DESC
LIMIT 3;
                     QUERY PLAN                     
----------------------------------------------------
 Limit
   Output: category, (sum(rating))
   ->  Sort
         Output: category, (sum(rating))
         Sort Key: (sum(mock_items.rating)) DESC
         ->  Custom Scan (ParadeDB Aggregate Scan)
               Output: category, (sum(rating))
               Backend: DataFusion
               Indexes: idx_mock_items (mock_items)
               Group By: category
               Aggregates: SUM(rating)
(11 rows)

SELECT category, SUM(rating)
FROM mock_items
WHERE mock_items @@@ paradedb.all()
GROUP BY category
ORDER BY SUM(rating) DESC
LIMIT 3;
  category   | sum 
-------------+-----
 Footwear    |  24
 Electronics |  20
 Photography |  18
(3 rows)

-- ================================================================
-- Test 3: ORDER BY COUNT(*) ASC LIMIT (bottom K)
-- ================================================================
EXPLAIN (COSTS OFF, VERBOSE, TIMING OFF)
SELECT category, COUNT(*)
FROM mock_items
WHERE mock_items @@@ paradedb.all()
GROUP BY category
ORDER BY COUNT(*) ASC
LIMIT 2;
                     QUERY PLAN                     
----------------------------------------------------
 Limit
   Output: category, (count(*))
   ->  Sort
         Output: category, (count(*))
         Sort Key: (count(*))
         ->  Custom Scan (ParadeDB Aggregate Scan)
               Output: category, (count(*))
               Backend: DataFusion
               Indexes: idx_mock_items (mock_items)
               Group By: category
               Aggregates: COUNT(*)
(11 rows)

SELECT category, COUNT(*)
FROM mock_items
WHERE mock_items @@@ paradedb.all()
GROUP BY category
ORDER BY COUNT(*) ASC
LIMIT 2;
 category  | count 
-----------+-------
 Furniture |     3
 Beauty    |     3
(2 rows)

-- ================================================================
-- Test 4: ORDER BY COUNT(*) DESC with OFFSET
-- ================================================================
SELECT category, COUNT(*)
FROM mock_items
WHERE mock_items @@@ paradedb.all()
GROUP BY category
ORDER BY COUNT(*) DESC
LIMIT 2 OFFSET 1;
  category   | count 
-------------+-------
 Electronics |     5
 Photography |     4
(2 rows)

-- ================================================================
-- Test 5: Parity check — DataFusion vs Postgres native
-- ================================================================
SET paradedb.enable_aggregate_custom_scan TO off;
SELECT category, COUNT(*), SUM(rating)
FROM mock_items
WHERE mock_items @@@ paradedb.all()
GROUP BY category
ORDER BY COUNT(*) DESC;
  category   | count | sum 
-------------+-------+-----
 Footwear    |     6 |  24
 Electronics |     5 |  20
 Books       |     4 |  10
 Toys        |     4 |  12
 Photography |     4 |  18
 Home Decor  |     4 |  18
 Apparel     |     4 |  17
 Groceries   |     4 |  17
 Beauty      |     3 |  10
 Furniture   |     3 |  12
(10 rows)

SET paradedb.enable_aggregate_custom_scan TO on;
SELECT category, COUNT(*), SUM(rating)
FROM mock_items
WHERE mock_items @@@ paradedb.all()
GROUP BY category
ORDER BY COUNT(*) DESC;
  category   | count | sum 
-------------+-------+-----
 Footwear    |     6 |  24
 Electronics |     5 |  20
 Groceries   |     4 |  17
 Toys        |     4 |  12
 Books       |     4 |  10
 Apparel     |     4 |  17
 Home Decor  |     4 |  18
 Photography |     4 |  18
 Beauty      |     3 |  10
 Furniture   |     3 |  12
(10 rows)

-- ================================================================
-- Test 6: Multiple aggregates with ORDER BY SUM — routed to DataFusion
-- ORDER BY SUM routes to DataFusion for correct NULL semantics.
-- ================================================================
EXPLAIN (COSTS OFF, VERBOSE, TIMING OFF)
SELECT category, COUNT(*), SUM(rating), MIN(rating), MAX(rating)
FROM mock_items
WHERE mock_items @@@ paradedb.all()
GROUP BY category
ORDER BY SUM(rating) DESC
LIMIT 3;
                                       QUERY PLAN                                        
-----------------------------------------------------------------------------------------
 Limit
   Output: category, (count(*)), (sum(rating)), (min(rating)), (max(rating))
   ->  Sort
         Output: category, (count(*)), (sum(rating)), (min(rating)), (max(rating))
         Sort Key: (sum(mock_items.rating)) DESC
         ->  Custom Scan (ParadeDB Aggregate Scan)
               Output: category, (count(*)), (sum(rating)), (min(rating)), (max(rating))
               Backend: DataFusion
               Indexes: idx_mock_items (mock_items)
               Group By: category
               Aggregates: COUNT(*), SUM(rating), MIN(rating), MAX(rating)
(11 rows)

SELECT category, COUNT(*), SUM(rating), MIN(rating), MAX(rating)
FROM mock_items
WHERE mock_items @@@ paradedb.all()
GROUP BY category
ORDER BY SUM(rating) DESC
LIMIT 3;
  category   | count | sum | min | max 
-------------+-------+-----+-----+-----
 Footwear    |     6 |  24 |   3 |   5
 Electronics |     5 |  20 |   3 |   5
 Photography |     4 |  18 |   4 |   5
(3 rows)

