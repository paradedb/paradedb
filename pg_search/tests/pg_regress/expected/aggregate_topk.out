\i common/common_setup.sql
CREATE EXTENSION IF NOT EXISTS pg_search;
-- Disable parallel workers to avoid differences in plans
SET max_parallel_workers_per_gather = 0;
SET enable_indexscan to OFF;
SET paradedb.enable_columnar_exec = true;
CREATE EXTENSION IF NOT EXISTS pg_search;
SET paradedb.enable_aggregate_custom_scan TO on;
-- Create test table
CALL paradedb.create_bm25_test_table(
    schema_name => 'public',
    table_name => 'mock_items'
);
CREATE INDEX idx_mock_items ON mock_items
    USING bm25 (id, description, category, rating, in_stock)
    WITH (
        key_field='id',
        text_fields='{"description": {}, "category": {"fast": true}}',
        numeric_fields='{"rating": {"fast": true}}',
        boolean_fields='{"in_stock": {"fast": true}}'
    );
-- Use a broad query to match items across multiple categories
-- ================================================================
-- Test 1: ORDER BY COUNT(*) DESC LIMIT (TopK by doc count)
-- ================================================================
EXPLAIN (COSTS OFF, VERBOSE, TIMING OFF)
SELECT category, COUNT(*)
FROM mock_items
WHERE mock_items @@@ paradedb.all()
GROUP BY category
ORDER BY COUNT(*) DESC
LIMIT 3;
                                                              QUERY PLAN                                                              
--------------------------------------------------------------------------------------------------------------------------------------
 Limit
   Output: category, (pdb.agg_fn('COUNT(*)'::text))
   ->  Sort
         Output: category, (pdb.agg_fn('COUNT(*)'::text))
         Sort Key: (pdb.agg_fn('COUNT(*)'::text)) DESC
         ->  Custom Scan (ParadeDB Aggregate Scan) on public.mock_items
               Output: category, pdb.agg_fn('COUNT(*)'::text)
               Index: idx_mock_items
               Tantivy Query: {"with_index":{"query":"all"}}
                 Applies to Aggregates: COUNT(*)
                 Group By: category
                 Limit: 3
                 TopK Order: COUNT(*) DESC
                 Aggregate Definition: {"grouped":{"terms":{"field":"category","order":{"_count":"desc"},"segment_size":3,"size":3}}}
(14 rows)

SELECT category, COUNT(*)
FROM mock_items
WHERE mock_items @@@ paradedb.all()
GROUP BY category
ORDER BY COUNT(*) DESC
LIMIT 3;
  category   | count 
-------------+-------
 Footwear    |     6
 Electronics |     5
 Apparel     |     4
(3 rows)

-- ================================================================
-- Test 2: ORDER BY SUM(field) DESC LIMIT (TopK by sub-aggregation)
-- ================================================================
EXPLAIN (COSTS OFF, VERBOSE, TIMING OFF)
SELECT category, SUM(rating)
FROM mock_items
WHERE mock_items @@@ paradedb.all()
GROUP BY category
ORDER BY SUM(rating) DESC
LIMIT 3;
                                                                                       QUERY PLAN                                                                                       
----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
 Limit
   Output: category, (pdb.agg_fn('SUM'::text))
   ->  Sort
         Output: category, (pdb.agg_fn('SUM'::text))
         Sort Key: (pdb.agg_fn('SUM'::text)) DESC
         ->  Custom Scan (ParadeDB Aggregate Scan) on public.mock_items
               Output: category, pdb.agg_fn('SUM'::text)
               Index: idx_mock_items
               Tantivy Query: {"with_index":{"query":"all"}}
                 Applies to Aggregates: SUM(rating)
                 Group By: category
                 Limit: 3
                 TopK Order: SUM(rating) DESC
                 Aggregate Definition: {"grouped":{"aggs":{"0":{"sum":{"field":"rating","missing":null}}},"terms":{"field":"category","order":{"0":"desc"},"segment_size":3,"size":3}}}
(14 rows)

SELECT category, SUM(rating)
FROM mock_items
WHERE mock_items @@@ paradedb.all()
GROUP BY category
ORDER BY SUM(rating) DESC
LIMIT 3;
  category   | sum 
-------------+-----
 Footwear    |  24
 Electronics |  20
 Home Decor  |  18
(3 rows)

-- ================================================================
-- Test 3: ORDER BY COUNT(*) ASC LIMIT (bottom K)
-- ================================================================
EXPLAIN (COSTS OFF, VERBOSE, TIMING OFF)
SELECT category, COUNT(*)
FROM mock_items
WHERE mock_items @@@ paradedb.all()
GROUP BY category
ORDER BY COUNT(*) ASC
LIMIT 2;
                                                             QUERY PLAN                                                              
-------------------------------------------------------------------------------------------------------------------------------------
 Limit
   Output: category, (pdb.agg_fn('COUNT(*)'::text))
   ->  Sort
         Output: category, (pdb.agg_fn('COUNT(*)'::text))
         Sort Key: (pdb.agg_fn('COUNT(*)'::text))
         ->  Custom Scan (ParadeDB Aggregate Scan) on public.mock_items
               Output: category, pdb.agg_fn('COUNT(*)'::text)
               Index: idx_mock_items
               Tantivy Query: {"with_index":{"query":"all"}}
                 Applies to Aggregates: COUNT(*)
                 Group By: category
                 Limit: 2
                 TopK Order: COUNT(*) ASC
                 Aggregate Definition: {"grouped":{"terms":{"field":"category","order":{"_count":"asc"},"segment_size":2,"size":2}}}
(14 rows)

SELECT category, COUNT(*)
FROM mock_items
WHERE mock_items @@@ paradedb.all()
GROUP BY category
ORDER BY COUNT(*) ASC
LIMIT 2;
 category  | count 
-----------+-------
 Beauty    |     3
 Furniture |     3
(2 rows)

-- ================================================================
-- Test 4: ORDER BY COUNT(*) DESC with OFFSET
-- ================================================================
SELECT category, COUNT(*)
FROM mock_items
WHERE mock_items @@@ paradedb.all()
GROUP BY category
ORDER BY COUNT(*) DESC
LIMIT 2 OFFSET 1;
  category   | count 
-------------+-------
 Electronics |     5
 Apparel     |     4
(2 rows)

-- ================================================================
-- Test 5: Parity check — DataFusion vs Postgres native
-- ================================================================
SET paradedb.enable_aggregate_custom_scan TO off;
SELECT category, COUNT(*), SUM(rating)
FROM mock_items
WHERE mock_items @@@ paradedb.all()
GROUP BY category
ORDER BY COUNT(*) DESC;
  category   | count | sum 
-------------+-------+-----
 Footwear    |     6 |  24
 Electronics |     5 |  20
 Books       |     4 |  10
 Toys        |     4 |  12
 Photography |     4 |  18
 Home Decor  |     4 |  18
 Apparel     |     4 |  17
 Groceries   |     4 |  17
 Beauty      |     3 |  10
 Furniture   |     3 |  12
(10 rows)

SET paradedb.enable_aggregate_custom_scan TO on;
SELECT category, COUNT(*), SUM(rating)
FROM mock_items
WHERE mock_items @@@ paradedb.all()
GROUP BY category
ORDER BY COUNT(*) DESC;
  category   | count | sum 
-------------+-------+-----
 Footwear    |     6 |  24
 Electronics |     5 |  20
 Groceries   |     4 |  17
 Toys        |     4 |  12
 Books       |     4 |  10
 Apparel     |     4 |  17
 Home Decor  |     4 |  18
 Photography |     4 |  18
 Beauty      |     3 |  10
 Furniture   |     3 |  12
(10 rows)

-- ================================================================
-- Test 6: Multiple aggregates with ORDER BY one of them
-- ================================================================
EXPLAIN (COSTS OFF, VERBOSE, TIMING OFF)
SELECT category, COUNT(*), SUM(rating), MIN(rating), MAX(rating)
FROM mock_items
WHERE mock_items @@@ paradedb.all()
GROUP BY category
ORDER BY SUM(rating) DESC
LIMIT 3;
                                                                                                                                     QUERY PLAN                                                                                                                                     
------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
 Limit
   Output: category, (pdb.agg_fn('COUNT(*)'::text)), (pdb.agg_fn('SUM'::text)), (pdb.agg_fn('MIN'::text)), (pdb.agg_fn('MAX'::text))
   ->  Sort
         Output: category, (pdb.agg_fn('COUNT(*)'::text)), (pdb.agg_fn('SUM'::text)), (pdb.agg_fn('MIN'::text)), (pdb.agg_fn('MAX'::text))
         Sort Key: (pdb.agg_fn('SUM'::text)) DESC
         ->  Custom Scan (ParadeDB Aggregate Scan) on public.mock_items
               Output: category, pdb.agg_fn('COUNT(*)'::text), pdb.agg_fn('SUM'::text), pdb.agg_fn('MIN'::text), pdb.agg_fn('MAX'::text)
               Index: idx_mock_items
               Tantivy Query: {"with_index":{"query":"all"}}
                 Applies to Aggregates: COUNT(*), SUM(rating), MIN(rating), MAX(rating)
                 Group By: category
                 Limit: 3
                 TopK Order: SUM(rating) DESC
                 Aggregate Definition: {"grouped":{"aggs":{"0":{"sum":{"field":"rating","missing":null}},"1":{"min":{"field":"rating","missing":null}},"2":{"max":{"field":"rating","missing":null}}},"terms":{"field":"category","order":{"0":"desc"},"segment_size":3,"size":3}}}
(14 rows)

SELECT category, COUNT(*), SUM(rating), MIN(rating), MAX(rating)
FROM mock_items
WHERE mock_items @@@ paradedb.all()
GROUP BY category
ORDER BY SUM(rating) DESC
LIMIT 3;
  category   | count | sum | min | max 
-------------+-------+-----+-----+-----
 Footwear    |     6 |  24 |   3 |   5
 Electronics |     5 |  20 |   3 |   5
 Home Decor  |     4 |  18 |   4 |   5
(3 rows)

