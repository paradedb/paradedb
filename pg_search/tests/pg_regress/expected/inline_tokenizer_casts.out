--
-- validate JSON representation of chained casts
--
SELECT 'running shoes'::pdb.whitespace::pdb.boost(3);
                                                  boost                                                  
---------------------------------------------------------------------------------------------------------
 {"score_adjusted":{"query":{"unclassified_array":{"array":["running","shoes"]}},"score":{"Boost":3.0}}}
(1 row)

SELECT 'running shoes'::pdb.whitespace::pdb.const(5);
                                                  const                                                  
---------------------------------------------------------------------------------------------------------
 {"score_adjusted":{"query":{"unclassified_array":{"array":["running","shoes"]}},"score":{"Const":5.0}}}
(1 row)

SELECT 'running shoes'::pdb.whitespace::pdb.fuzzy(2);
                                                             fuzzy                                                              
--------------------------------------------------------------------------------------------------------------------------------
 {"unclassified_array":{"array":["running","shoes"],"fuzzy_data":{"distance":2,"prefix":false,"transposition_cost_one":false}}}
(1 row)

SELECT 'running shoes'::pdb.fuzzy(2)::pdb.boost(3);
                                                                                      boost                                                                                      
---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
 {"score_adjusted":{"query":{"unclassified_string":{"string":"running shoes","fuzzy_data":{"distance":2,"prefix":false,"transposition_cost_one":false}}},"score":{"Boost":3.0}}}
(1 row)

SELECT 'running shoes'::pdb.fuzzy(2)::pdb.const(3);
                                                                                      const                                                                                      
---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
 {"score_adjusted":{"query":{"unclassified_string":{"string":"running shoes","fuzzy_data":{"distance":2,"prefix":false,"transposition_cost_one":false}}},"score":{"Const":3.0}}}
(1 row)

SELECT 'running shoes'::pdb.slop(2)::pdb.boost(3);
                                                            boost                                                             
------------------------------------------------------------------------------------------------------------------------------
 {"score_adjusted":{"query":{"unclassified_string":{"string":"running shoes","slop_data":{"slop":2}}},"score":{"Boost":3.0}}}
(1 row)

SELECT 'running shoes'::pdb.slop(2)::pdb.const(3);
                                                            const                                                             
------------------------------------------------------------------------------------------------------------------------------
 {"score_adjusted":{"query":{"unclassified_string":{"string":"running shoes","slop_data":{"slop":2}}},"score":{"Const":3.0}}}
(1 row)

--
-- end-to-end scoring: tokenizer -> boost scales linearly vs plain text baseline
--
SELECT id, paradedb.score(id) AS score
FROM mock_items
WHERE description &&& 'shoes'
ORDER BY id;
 id |   score   
----+-----------
  3 | 2.4849067
  4 | 2.4849067
  5 | 2.8772602
(3 rows)

SELECT id, paradedb.score(id) AS score
FROM mock_items
WHERE description &&& 'shoes'::pdb.whitespace::pdb.boost(3)
ORDER BY id;
 id |  score   
----+----------
  3 |  7.45472
  4 |  7.45472
  5 | 8.631781
(3 rows)

--
-- end-to-end scoring: tokenizer -> const assigns a fixed score
--
SELECT id, paradedb.score(id) AS score
FROM mock_items
WHERE description &&& 'shoes'::pdb.whitespace::pdb.const(5)
ORDER BY id;
 id | score 
----+-------
  3 |     5
  4 |     5
  5 |     5
(3 rows)

-- Clean up
DROP TABLE mock_items CASCADE;
