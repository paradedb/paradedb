 description | Str        | f      | t       | t    | f          |             | literal_normalized[ascii_folding=true] | basic  | lowercase
 id          | I64        | f      | t       | t    | f          |             |                                        |        | 
(3 rows)

EXPLAIN (FORMAT TEXT, COSTS OFF, TIMING OFF)
SELECT * FROM test
WHERE lower(description) === 'cloud engineer'
ORDER BY lower(description)
LIMIT 10;
