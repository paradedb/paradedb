                             :     SegmentedTopKExec: expr=[col_2@1 ASC NULLS LAST], k=10
                             :       VisibilityFilterExec: tables=[s, p]
                             :         HashJoinExec: mode=CollectLeft, join_type=Inner, on=[(id@1, supplier_id@1)], projection=[ctid_0@0, name@2, ctid_1@3, name@5]
