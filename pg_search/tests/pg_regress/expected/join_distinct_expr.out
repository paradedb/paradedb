-- =============================================================================
-- CLEANUP
-- =============================================================================
DROP TABLE IF EXISTS dex_products CASCADE;
DROP TABLE IF EXISTS dex_suppliers CASCADE;
RESET max_parallel_workers_per_gather;
RESET enable_indexscan;
