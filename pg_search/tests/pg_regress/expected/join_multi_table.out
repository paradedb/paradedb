-- Order by score from the nested relation (Products).
-- Products is in the child join (p join c).
EXPLAIN (COSTS OFF, VERBOSE, TIMING OFF)
SELECT p.name, paradedb.score(p.id)
FROM products p
JOIN suppliers s ON p.supplier_id = s.id
JOIN categories c ON p.category_id = c.id
WHERE p.description @@@ 'wireless'
ORDER BY paradedb.score(p.id) DESC
LIMIT 5;
                                                                                                       QUERY PLAN                                                                                                        
-------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
 Limit
   Output: p.name, (paradedb.score(p.id))
   ->  Custom Scan (ParadeDB Join Scan)
         Output: p.name, (paradedb.score(p.id))
         Relation Tree: s INNER (c INNER p)
         Join Cond: p.supplier_id = s.id, p.category_id = c.id
         Limit: 5
         Order By: pdb.score() desc
         DataFusion Physical Plan: 
           : ProjectionExec: expr=[NULL as col_1, score@2 as col_2, ctid_0@0 as ctid_0, ctid_1@1 as ctid_1, ctid_2@3 as ctid_2]
           :   SortExec: TopK(fetch=5), expr=[score@2 DESC], preserve_partitioning=[false]
           :     VisibilityFilterExec: tables=[s, c, p]
           :       ProjectionExec: expr=[ctid_0@0 as ctid_0, ctid_1@3 as ctid_1, score@1 as score, ctid_2@2 as ctid_2]
           :         HashJoinExec: mode=CollectLeft, join_type=Inner, on=[(category_id@3, id@1)], projection=[ctid_0@0, score@1, ctid_2@2, ctid_1@4]
           :           ProjectionExec: expr=[ctid_0@3 as ctid_0, score@0 as score, ctid_2@1 as ctid_2, category_id@2 as category_id]
           :             HashJoinExec: mode=CollectLeft, join_type=Inner, on=[(supplier_id@2, id@1)], projection=[score@0, ctid_2@1, category_id@3, ctid_0@4]
           :               ProjectionExec: expr=[pdb.score()@0 as score, ctid_2@1 as ctid_2, supplier_id@2 as supplier_id, category_id@3 as category_id]
           :                 CooperativeExec
           :                   PgSearchScan: segments=1, dynamic_filters=1, query={"with_index":{"query":{"parse_with_field":{"field":"description","query_string":"wireless","lenient":null,"conjunction_mode":null}}}}
           :               CooperativeExec
           :                 PgSearchScan: segments=1, dynamic_filters=1, query="all"
           :           CooperativeExec
           :             PgSearchScan: segments=1, dynamic_filters=1, query="all"
(23 rows)

