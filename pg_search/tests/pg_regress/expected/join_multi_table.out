SELECT l1.name, l2.name, l3.name, l4.name
FROM level1 l1
JOIN level2 l2 ON l1.l2_id = l2.id
JOIN level3 l3 ON l2.l3_id = l3.id
JOIN level4 l4 ON l3.l4_id = l4.id
WHERE l4.description @@@ 'deepest'
ORDER BY l1.id
LIMIT 5;
