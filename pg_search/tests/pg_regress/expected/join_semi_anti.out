  20 | target_category
  30 | target_category
  40 | target_category
  50 | target_category
  60 | target_category
  70 | target_category
  80 | target_category
  90 | target_category
 100 | target_category
(10 rows)

-- =====================================================================
-- 5. SELECT * and ORDER BY varchar column (RelabelType wrapper reproduction)
-- =====================================================================
EXPLAIN (COSTS OFF, VERBOSE, TIMING OFF)
SELECT *
FROM table_a
WHERE id IN (
    SELECT a_id
    FROM table_b
    WHERE group_id IN ('group_1')
)
AND id @@@ 'category:"target_category"'
ORDER BY category ASC, id ASC
LIMIT 10;
                                                                                                          QUERY PLAN                                                                                                          
------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
 Limit
   Output: table_a.id, table_a.category
   ->  Custom Scan (ParadeDB Join Scan)
         Output: table_a.id, table_a.category
         Relation Tree: table_a SEMI table_b
         Join Cond: table_a.id = table_b.a_id
         Limit: 10
         Order By: table_a.category asc, table_a.id asc
         DataFusion Physical Plan: 
           : ProjectionExec: expr=[id@1 as col_1, category@2 as col_2, ctid_0@0 as ctid_0]
           :   TantivyLookupExec: decode=[category]
           :     SegmentedTopKExec: expr=[category@2 ASC NULLS LAST, id@1 ASC NULLS LAST], k=10
           :       HashJoinExec: mode=CollectLeft, join_type=LeftSemi, on=[(id@1, a_id@0)]
           :         VisibilityFilterExec: tables=[table_a]
           :           CooperativeExec
           :             PgSearchScan: segments=1, dynamic_filters=1, query={"with_index":{"query":{"parse_with_field":{"field":"id","query_string":"category:\"target_category\"","lenient":null,"conjunction_mode":null}}}}
           :         CooperativeExec
           :           PgSearchScan: segments=1, query={"term":{"field":"group_id","value":"group_1","is_datetime":false}}
(18 rows)

