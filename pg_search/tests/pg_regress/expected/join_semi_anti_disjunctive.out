SET paradedb.enable_join_custom_scan TO off;
SELECT i.id
FROM items_vc i
WHERE NOT EXISTS (
    SELECT 1 FROM exclusions_vc e
    WHERE e.id @@@ paradedb.all()
      AND (e.pattern = i.name OR e.pattern = i.alt_name)
)
AND i.id @@@ 'category:"target"'
ORDER BY i.id DESC
LIMIT 10;
