SET paradedb.enable_join_custom_scan TO on;
DROP TABLE items_vc CASCADE;
DROP TABLE exclusions_vc CASCADE;
-- Cleanup
DROP TABLE items CASCADE;
DROP TABLE exclusions CASCADE;
RESET paradedb.enable_join_custom_scan;
