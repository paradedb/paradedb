-- =====================================================================
-- 3. NOT EXISTS with 3-arm OR
-- =====================================================================
EXPLAIN (COSTS OFF, TIMING OFF)
SELECT i.id
FROM items i
WHERE NOT EXISTS (
    SELECT 1 FROM exclusions e
    WHERE e.id @@@ paradedb.all()
      AND (
          e.pattern = i.name
          OR e.pattern = i.alt_name
          OR e.pattern = i.category
      )
)
AND i.id @@@ 'category:"target"'
ORDER BY i.id DESC
LIMIT 10;
