SELECT i.id
FROM items i
WHERE NOT EXISTS (
    SELECT 1 FROM exclusions e
    WHERE e.id @@@ paradedb.all()
      AND (e.pattern = i.name OR e.pattern = i.alt_name)
)
AND i.id @@@ 'category:"other"'
ORDER BY i.id DESC
LIMIT 10;
