           :       VisibilityFilterExec: tables=[i]
           :         CooperativeExec
           :           PgSearchScan: segments=1, query={"with_index":{"query":{"parse_with_field":{"field":"id","query_string":"category:\"target\"","lenient":null,"conjunction_mode":null}}}}
