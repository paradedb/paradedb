   ->  Custom Scan (ParadeDB Base Scan) on json_range_test
         Table: json_range_test
         Index: json_range_test_idx
         Exec Method: ColumnarExecState
         Fast Fields: id
         Scores: false
         Tantivy Query: {"with_index":{"query":{"range":{"field":"metadata.attributes.score","lower_bound":{"included":4},"upper_bound":null}}}}
(9 rows)

SELECT id FROM json_range_test
WHERE id @@@ '{
    "range": {
        "field": "metadata.attributes.score",
        "lower_bound": {"included": 4},
        "upper_bound": null
    }
}'::jsonb
ORDER BY id;
 id 
