SELECT id, title
FROM docs
WHERE id @@@ paradedb.boolean(
    must => ARRAY[paradedb.term('body', 'fruit')],
    should => ARRAY[
        paradedb.term('title', 'apple'),
        paradedb.term('title', 'banana'),
        paradedb.term('title', 'cherry')
    ],
    minimum_should_match => 2
)
