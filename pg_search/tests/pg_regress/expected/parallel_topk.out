(11 rows)

-- ============================================================
-- Scenario 7: unordered_topk_large_match_small_k
--
-- No ORDER BY, but LIMIT still uses TopKScanExecState. The executor calls
-- `.skip(offset).take(limit)`, so work is bounded by LIMIT + OFFSET rather
-- than the full match estimate. This guards against making small LIMIT
-- unordered searches look expensive enough to pick a parallel Gather.
-- Expected: SERIAL.
-- ============================================================
EXPLAIN (COSTS OFF, VERBOSE, TIMING OFF)
SELECT id FROM topk_desc_large WHERE body @@@ 'gamma'
LIMIT 10;
                                                                     QUERY PLAN                                                                      
-----------------------------------------------------------------------------------------------------------------------------------------------------
 Limit
   Output: id
   ->  Custom Scan (ParadeDB Base Scan) on public.topk_desc_large
         Output: id
         Table: topk_desc_large
         Index: topk_desc_large_idx
         Exec Method: TopKScanExecState
         Scores: false
            TopK Limit: 10
         Tantivy Query: {"with_index":{"query":{"parse_with_field":{"field":"body","query_string":"gamma","lenient":null,"conjunction_mode":null}}}}
(10 rows)

-- ============================================================
-- Scenario 8: topk_desc_with_window_aggregate
--
-- Score-DESC TopK with a window aggregate (`pdb.agg(...) OVER ()`).
-- The `window_aggregates` field is still empty during create_custom_path, so
-- `is_score_desc_topk` uses recursive target-list detection to reject this
-- shape before the cost branch. It then uses the general `compute_nworkers`
-- worker-selection path. The bounded-TopK cost decision must NOT run for this
-- shape; the proof is that we never invoke our cost formula here.
--
-- The plan ends up PARALLEL through general worker selection. The point of the
-- scenario is not the serial/parallel outcome — it's that the executor uses
-- `TopKScanExecState` outside the bounded-TopK cost path.
-- Expected: PARALLEL with TopK exec method.
-- ============================================================
EXPLAIN (COSTS OFF, VERBOSE, TIMING OFF)
SELECT id,
       paradedb.score(id),
       pdb.agg('{"terms": {"field": "body", "size": 5}}', false) OVER () AS body_facets
FROM topk_desc_large
WHERE body @@@ 'alpha'
ORDER BY paradedb.score(id) DESC
LIMIT 10;
                                                                                                                                     QUERY PLAN                                                                                                                                      
-------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
 Limit
   Output: id, (paradedb.score(id)), (pdb.window_agg('{"entries":[{"Aggregate":{"Custom":{"agg_json":{"terms":{"size":5,"field":"body"}},"filter":null,"indexrelid":0,"mvcc_visibility":"Disabled"}}}],"groupby":{"grouping_columns":[]},"uses_our_operator":false}'::text))
   ->  Gather Merge
         Output: id, (paradedb.score(id)), (pdb.window_agg('{"entries":[{"Aggregate":{"Custom":{"agg_json":{"terms":{"size":5,"field":"body"}},"filter":null,"indexrelid":0,"mvcc_visibility":"Disabled"}}}],"groupby":{"grouping_columns":[]},"uses_our_operator":false}'::text))
         Workers Planned: 2
         ->  Parallel Custom Scan (ParadeDB Base Scan) on public.topk_desc_large
               Output: id, paradedb.score(id), pdb.window_agg('{"entries":[{"Aggregate":{"Custom":{"agg_json":{"terms":{"size":5,"field":"body"}},"filter":null,"indexrelid":0,"mvcc_visibility":"Disabled"}}}],"groupby":{"grouping_columns":[]},"uses_our_operator":false}'::text)
               Table: topk_desc_large
               Index: topk_desc_large_idx
               Exec Method: TopKScanExecState
               Scores: true
                  TopK Order By: pdb.score() desc
                  TopK Limit: 10
               Tantivy Query: {"with_index":{"query":{"parse_with_field":{"field":"body","query_string":"alpha","lenient":null,"conjunction_mode":null}}}}
(14 rows)

-- ============================================================
-- Scenario 9: unanalyzed_topk_desc
--
-- Table with index but no ANALYZE, so reltuples is -1 and row_estimate is
-- Unknown. Score-DESC TopK should still use bounded-TopK costing and choose
-- SERIAL for this small LIMIT/few-segment shape. If it falls back to the
-- general sorted-output worker path, this shape would become PARALLEL.
-- Expected: SERIAL, reltuples = -1.
-- ============================================================
DROP TABLE IF EXISTS topk_unanalyzed CASCADE;
CREATE TABLE topk_unanalyzed (id INTEGER GENERATED ALWAYS AS IDENTITY PRIMARY KEY, body TEXT NOT NULL);
CREATE INDEX topk_unanalyzed_idx ON topk_unanalyzed USING bm25 (id, body)
    WITH (key_field = 'id', target_segment_count = 4,
          layer_sizes = '10TB', background_layer_sizes = '10TB');
INSERT INTO topk_unanalyzed (body) SELECT 'alpha beta' FROM generate_series(1, 100);
INSERT INTO topk_unanalyzed (body) SELECT 'alpha beta' FROM generate_series(1, 100);
-- intentionally NOT calling ANALYZE
SELECT relname, reltuples FROM pg_class WHERE relname = 'topk_unanalyzed';
     relname     | reltuples 
-----------------+-----------
 topk_unanalyzed |        -1
(1 row)

EXPLAIN (COSTS OFF, VERBOSE, TIMING OFF)
SELECT id FROM topk_unanalyzed WHERE body @@@ 'alpha'
ORDER BY paradedb.score(id) DESC LIMIT 10;
                                                                     QUERY PLAN                                                                      
-----------------------------------------------------------------------------------------------------------------------------------------------------
 Limit
   Output: id, (paradedb.score(id))
   ->  Custom Scan (ParadeDB Base Scan) on public.topk_unanalyzed
         Output: id, paradedb.score(id)
         Table: topk_unanalyzed
         Index: topk_unanalyzed_idx
         Exec Method: TopKScanExecState
         Scores: true
            TopK Order By: pdb.score() desc
            TopK Limit: 10
         Tantivy Query: {"with_index":{"query":{"parse_with_field":{"field":"body","query_string":"alpha","lenient":null,"conjunction_mode":null}}}}
(11 rows)

-- ============================================================
-- Scenario 10: topk_desc_with_score_projection (forced-path preservation)
--
-- Selecting `paradedb.score(id)` forces the ParadeDB custom path. Even forced,
-- the planner must be able to choose between serial and parallel ParadeDB paths.
-- Expected: SERIAL (same as scenario 1), Custom Scan node present.
-- ============================================================
EXPLAIN (COSTS OFF, VERBOSE, TIMING OFF)
SELECT id, paradedb.score(id) FROM topk_desc_large WHERE body @@@ 'alpha'
ORDER BY paradedb.score(id) DESC LIMIT 10;
                                                                     QUERY PLAN                                                                      
-----------------------------------------------------------------------------------------------------------------------------------------------------
 Limit
   Output: id, (paradedb.score(id))
   ->  Custom Scan (ParadeDB Base Scan) on public.topk_desc_large
         Output: id, paradedb.score(id)
         Table: topk_desc_large
         Index: topk_desc_large_idx
         Exec Method: TopKScanExecState
         Scores: true
            TopK Order By: pdb.score() desc
            TopK Limit: 10
         Tantivy Query: {"with_index":{"query":{"parse_with_field":{"field":"body","query_string":"alpha","lenient":null,"conjunction_mode":null}}}}
(11 rows)

-- ============================================================
-- Scenario 11: topk_desc_with_secondary_sort_key
--
-- `ORDER BY pdb.score(id) DESC, id ASC`: first sort key is score-DESC but
-- there's a secondary tiebreaker. The executor's `search_top_k_in_segments`
-- routes this to the generic `TopDocs::order_by` path instead of the
-- Block-WAND specialized score-only path, which means work is NOT bounded
-- by local TopK; every match is scored. The bounded TopK cost assumption would
-- be wrong here, so the score-only collector gate routes
-- this past the bounded-TopK cost decision to `compute_nworkers`.
-- That path correctly picks parallel for sorted output with multiple segments,
-- preserving James's #4077-class workloads on this shape.
-- Expected: PARALLEL via general worker selection.
-- ============================================================
EXPLAIN (COSTS OFF, VERBOSE, TIMING OFF)
SELECT id FROM topk_desc_large WHERE body @@@ 'alpha'
ORDER BY paradedb.score(id) DESC, id ASC LIMIT 10;
                                                                        QUERY PLAN                                                                         
-----------------------------------------------------------------------------------------------------------------------------------------------------------
 Limit
   Output: id, (paradedb.score(id))
   ->  Gather Merge
         Output: id, (paradedb.score(id))
         Workers Planned: 2
         ->  Parallel Custom Scan (ParadeDB Base Scan) on public.topk_desc_large
               Output: id, paradedb.score(id)
               Table: topk_desc_large
               Index: topk_desc_large_idx
               Exec Method: TopKScanExecState
               Scores: true
                  TopK Order By: pdb.score() desc, id asc
                  TopK Limit: 10
               Tantivy Query: {"with_index":{"query":{"parse_with_field":{"field":"body","query_string":"alpha","lenient":null,"conjunction_mode":null}}}}
(14 rows)

-- ============================================================
-- Scenario 12: topk_desc_phrase_not_blockwand_prunable
--
-- Phrase queries build a Tantivy `PhraseWeight`, whose `for_each_pruning`
-- uses the default scorer walk instead of Block-WAND. The planner resolves
-- the query to its actual Tantivy shape, sees that it is not a TermQuery or
-- pure term union, and routes this query past the bounded-TopK cost decision
-- to `compute_nworkers`.
-- Expected: PARALLEL via general worker selection.
-- ============================================================
EXPLAIN (COSTS OFF, VERBOSE, TIMING OFF)
SELECT id FROM topk_desc_large WHERE body @@@ pdb.phrase(ARRAY['alpha', 'beta'])
ORDER BY paradedb.score(id) DESC LIMIT 10;
                                                        QUERY PLAN                                                        
--------------------------------------------------------------------------------------------------------------------------
 Limit
   Output: id, (paradedb.score(id))
   ->  Gather Merge
         Output: id, (paradedb.score(id))
         Workers Planned: 2
         ->  Parallel Custom Scan (ParadeDB Base Scan) on public.topk_desc_large
               Output: id, paradedb.score(id)
               Table: topk_desc_large
               Index: topk_desc_large_idx
               Exec Method: TopKScanExecState
               Scores: true
                  TopK Order By: pdb.score() desc
                  TopK Limit: 10
               Tantivy Query: {"with_index":{"query":{"phrase":{"field":"body","phrases":["alpha","beta"],"slop":null}}}}
(14 rows)

-- ============================================================
-- Scenario 13: topk_desc_parameterized_limit_generic
--
-- A generic prepared plan keeps LIMIT as a Param, so the planner does not
-- have a trustworthy LIMIT + OFFSET cap for the bounded-TopK cost comparison.
-- The query must route to the general worker-selection path instead of using
-- DEFAULT_PARAMETERIZED_LIMIT_ESTIMATE as if it were the real LIMIT.
-- Expected: PARALLEL via general worker selection.
-- ============================================================
SET plan_cache_mode = force_generic_plan;
PREPARE topk_desc_param_limit(int) AS
SELECT id FROM topk_desc_large WHERE body @@@ 'alpha'
ORDER BY paradedb.score(id) DESC LIMIT $1;
\pset tuples_only on
EXPLAIN (COSTS OFF, VERBOSE, TIMING OFF)
EXECUTE topk_desc_param_limit(10);
 Limit
   Output: id, (paradedb.score(id))
   ->  Gather Merge
         Output: id, (paradedb.score(id))
         Workers Planned: 2
         ->  Parallel Custom Scan (ParadeDB Base Scan) on public.topk_desc_large
               Output: id, paradedb.score(id)
               Table: topk_desc_large
               Index: topk_desc_large_idx
               Exec Method: TopKScanExecState
               Scores: true
                  TopK Order By: pdb.score() desc
               Tantivy Query: {"with_index":{"query":{"parse_with_field":{"field":"body","query_string":"alpha","lenient":null,"conjunction_mode":null}}}}

\pset tuples_only off
DEALLOCATE topk_desc_param_limit;
RESET plan_cache_mode;
-- ============================================================
-- Cleanup
-- ============================================================
DROP TABLE topk_desc_large CASCADE;
DROP TABLE topk_desc_many_segs CASCADE;
DROP TABLE topk_asc_small CASCADE;
DROP TABLE topk_unanalyzed CASCADE;
