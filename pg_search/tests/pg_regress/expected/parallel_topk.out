-- Test for issue #4664: TopK parallelism should be cost-based for the shape
-- where Block-WAND pruning makes the leader finish before workers spin up.
--
-- The fix is scoped to **score-DESC TopK with one score sort key, no window
-- aggregates, and a resolved Tantivy query that uses Block-WAND score
-- pruning**:
--   - For that shape we compute serial and parallel costs in Rust (including
--     an estimate of PG's Gather wrap overhead) and emit exactly one path
--     with the chosen worker count. The cost formula caps row work at
--     `min(matches, (LIMIT + OFFSET) * segment_count)` and adds a per-segment
--     fixed cost (`paradedb.per_segment_cost`).
--   - All other TopK shapes (score-ASC, field-sort, unordered TopK, TopK with
--     window aggregates, or non-prunable query shapes) use the general
--     `compute_nworkers` worker-selection path. This preserves
--     James's benchmarked score-ASC parallel speedup (#4664: `'the' ORDER BY
--     score ASC LIMIT 10` 427ms -> 162ms) and avoids the cost-model blind spot
--     where `parallel_tuple_cost * match_count` is charged regardless of outer
--     LIMIT clipping.
--
-- The gate (`is_score_desc_topk` in basescan/mod.rs) keeps bounded-TopK
-- costing narrow enough that no benchmark calibration is required to avoid
-- regressing the non-score-DESC shapes. Both branches emit one path; only
-- the *how* of choosing serial-vs-parallel differs.
--
-- The index options `layer_sizes = '10TB'`, `background_layer_sizes = '10TB'`,
-- and `mutable_segment_rows = 10` are used to keep segments from merging during
-- the test, so segment counts are deterministic.
--
-- See:
--   - https://github.com/paradedb/paradedb/issues/4664 (this bug)
--   - https://github.com/paradedb/paradedb/issues/4077 (the regression we must not re-break)
--   - https://github.com/paradedb/paradedb/pull/4457 (the previous fix for #4077,
--     whose "always parallel for sorted output" invariant is what #4664 narrows)
CREATE EXTENSION IF NOT EXISTS pg_search;
-- Standard knobs. The cost defaults are PG's defaults; we want them visible
-- so the per-test settings stand out.
SET max_parallel_workers_per_gather = 2;
SET max_parallel_workers = 8;
SET parallel_setup_cost = 1000;
SET parallel_tuple_cost = 0.1;
SET cpu_tuple_cost = 0.01;
SET min_parallel_table_scan_size = 0;
SET paradedb.min_rows_per_worker = 300000;
SET paradedb.per_segment_cost = 50;
-- ============================================================
-- Scenario 1: topk_desc_large_match_small_k  (#4664 headline)
--
-- Many rows match, score-desc, small LIMIT. With few segments, Block-WAND pruning
-- makes per-segment work cheap; the leader can finish before workers spin up.
-- Expected: SERIAL.
-- ============================================================
DROP TABLE IF EXISTS topk_desc_large CASCADE;
CREATE TABLE topk_desc_large (id INTEGER GENERATED ALWAYS AS IDENTITY PRIMARY KEY, body TEXT NOT NULL);
CREATE INDEX topk_desc_large_idx ON topk_desc_large USING bm25 (id, body)
    WITH (key_field = 'id', target_segment_count = 4,
          layer_sizes = '10TB', background_layer_sizes = '10TB');
-- Four big batches -> ~4 segments. ~33% match 'alpha', ~67% match 'gamma'.
INSERT INTO topk_desc_large (body) SELECT CASE WHEN g % 3 = 0 THEN 'alpha beta' ELSE 'gamma delta' END FROM generate_series(1, 5000) g;
INSERT INTO topk_desc_large (body) SELECT CASE WHEN g % 3 = 0 THEN 'alpha beta' ELSE 'gamma delta' END FROM generate_series(1, 5000) g;
INSERT INTO topk_desc_large (body) SELECT CASE WHEN g % 3 = 0 THEN 'alpha beta' ELSE 'gamma delta' END FROM generate_series(1, 5000) g;
INSERT INTO topk_desc_large (body) SELECT CASE WHEN g % 3 = 0 THEN 'alpha beta' ELSE 'gamma delta' END FROM generate_series(1, 5000) g;
ANALYZE topk_desc_large;
EXPLAIN (COSTS OFF, VERBOSE, TIMING OFF)
SELECT id FROM topk_desc_large WHERE body @@@ 'alpha'
ORDER BY paradedb.score(id) DESC LIMIT 10;
                                                                     QUERY PLAN                                                                      
-----------------------------------------------------------------------------------------------------------------------------------------------------
 Limit
   Output: id, (paradedb.score(id))
   ->  Custom Scan (ParadeDB Base Scan) on public.topk_desc_large
         Output: id, paradedb.score(id)
         Table: topk_desc_large
         Index: topk_desc_large_idx
         Exec Method: TopKScanExecState
         Scores: true
            TopK Order By: pdb.score() desc
            TopK Limit: 10
         Tantivy Query: {"with_index":{"query":{"parse_with_field":{"field":"body","query_string":"alpha","lenient":null,"conjunction_mode":null}}}}
(11 rows)

-- ============================================================
-- Scenario 2: topk_desc_small_match_many_segs  (#4077 regression)
--
-- Few rows, MANY segments. Segment-walk cost dominates worker startup.
-- Expected: PARALLEL.
-- ============================================================
DROP TABLE IF EXISTS topk_desc_many_segs CASCADE;
CREATE TABLE topk_desc_many_segs (id INTEGER GENERATED ALWAYS AS IDENTITY PRIMARY KEY, body TEXT NOT NULL);
CREATE INDEX topk_desc_many_segs_idx ON topk_desc_many_segs USING bm25 (id, body)
    WITH (key_field = 'id', target_segment_count = 32, mutable_segment_rows = 10,
          layer_sizes = '10TB', background_layer_sizes = '10TB');
-- 32 separate INSERT statements -> 32+ sealed segments. Each batch has 1 'rare'.
INSERT INTO topk_desc_many_segs (body) SELECT CASE WHEN g = 1 THEN 'rare token' ELSE 'common other' END FROM generate_series(1, 50) g;
INSERT INTO topk_desc_many_segs (body) SELECT CASE WHEN g = 1 THEN 'rare token' ELSE 'common other' END FROM generate_series(1, 50) g;
INSERT INTO topk_desc_many_segs (body) SELECT CASE WHEN g = 1 THEN 'rare token' ELSE 'common other' END FROM generate_series(1, 50) g;
INSERT INTO topk_desc_many_segs (body) SELECT CASE WHEN g = 1 THEN 'rare token' ELSE 'common other' END FROM generate_series(1, 50) g;
INSERT INTO topk_desc_many_segs (body) SELECT CASE WHEN g = 1 THEN 'rare token' ELSE 'common other' END FROM generate_series(1, 50) g;
INSERT INTO topk_desc_many_segs (body) SELECT CASE WHEN g = 1 THEN 'rare token' ELSE 'common other' END FROM generate_series(1, 50) g;
INSERT INTO topk_desc_many_segs (body) SELECT CASE WHEN g = 1 THEN 'rare token' ELSE 'common other' END FROM generate_series(1, 50) g;
INSERT INTO topk_desc_many_segs (body) SELECT CASE WHEN g = 1 THEN 'rare token' ELSE 'common other' END FROM generate_series(1, 50) g;
INSERT INTO topk_desc_many_segs (body) SELECT CASE WHEN g = 1 THEN 'rare token' ELSE 'common other' END FROM generate_series(1, 50) g;
INSERT INTO topk_desc_many_segs (body) SELECT CASE WHEN g = 1 THEN 'rare token' ELSE 'common other' END FROM generate_series(1, 50) g;
INSERT INTO topk_desc_many_segs (body) SELECT CASE WHEN g = 1 THEN 'rare token' ELSE 'common other' END FROM generate_series(1, 50) g;
INSERT INTO topk_desc_many_segs (body) SELECT CASE WHEN g = 1 THEN 'rare token' ELSE 'common other' END FROM generate_series(1, 50) g;
INSERT INTO topk_desc_many_segs (body) SELECT CASE WHEN g = 1 THEN 'rare token' ELSE 'common other' END FROM generate_series(1, 50) g;
INSERT INTO topk_desc_many_segs (body) SELECT CASE WHEN g = 1 THEN 'rare token' ELSE 'common other' END FROM generate_series(1, 50) g;
INSERT INTO topk_desc_many_segs (body) SELECT CASE WHEN g = 1 THEN 'rare token' ELSE 'common other' END FROM generate_series(1, 50) g;
INSERT INTO topk_desc_many_segs (body) SELECT CASE WHEN g = 1 THEN 'rare token' ELSE 'common other' END FROM generate_series(1, 50) g;
INSERT INTO topk_desc_many_segs (body) SELECT CASE WHEN g = 1 THEN 'rare token' ELSE 'common other' END FROM generate_series(1, 50) g;
INSERT INTO topk_desc_many_segs (body) SELECT CASE WHEN g = 1 THEN 'rare token' ELSE 'common other' END FROM generate_series(1, 50) g;
INSERT INTO topk_desc_many_segs (body) SELECT CASE WHEN g = 1 THEN 'rare token' ELSE 'common other' END FROM generate_series(1, 50) g;
INSERT INTO topk_desc_many_segs (body) SELECT CASE WHEN g = 1 THEN 'rare token' ELSE 'common other' END FROM generate_series(1, 50) g;
INSERT INTO topk_desc_many_segs (body) SELECT CASE WHEN g = 1 THEN 'rare token' ELSE 'common other' END FROM generate_series(1, 50) g;
INSERT INTO topk_desc_many_segs (body) SELECT CASE WHEN g = 1 THEN 'rare token' ELSE 'common other' END FROM generate_series(1, 50) g;
INSERT INTO topk_desc_many_segs (body) SELECT CASE WHEN g = 1 THEN 'rare token' ELSE 'common other' END FROM generate_series(1, 50) g;
INSERT INTO topk_desc_many_segs (body) SELECT CASE WHEN g = 1 THEN 'rare token' ELSE 'common other' END FROM generate_series(1, 50) g;
INSERT INTO topk_desc_many_segs (body) SELECT CASE WHEN g = 1 THEN 'rare token' ELSE 'common other' END FROM generate_series(1, 50) g;
INSERT INTO topk_desc_many_segs (body) SELECT CASE WHEN g = 1 THEN 'rare token' ELSE 'common other' END FROM generate_series(1, 50) g;
INSERT INTO topk_desc_many_segs (body) SELECT CASE WHEN g = 1 THEN 'rare token' ELSE 'common other' END FROM generate_series(1, 50) g;
INSERT INTO topk_desc_many_segs (body) SELECT CASE WHEN g = 1 THEN 'rare token' ELSE 'common other' END FROM generate_series(1, 50) g;
INSERT INTO topk_desc_many_segs (body) SELECT CASE WHEN g = 1 THEN 'rare token' ELSE 'common other' END FROM generate_series(1, 50) g;
INSERT INTO topk_desc_many_segs (body) SELECT CASE WHEN g = 1 THEN 'rare token' ELSE 'common other' END FROM generate_series(1, 50) g;
INSERT INTO topk_desc_many_segs (body) SELECT CASE WHEN g = 1 THEN 'rare token' ELSE 'common other' END FROM generate_series(1, 50) g;
INSERT INTO topk_desc_many_segs (body) SELECT CASE WHEN g = 1 THEN 'rare token' ELSE 'common other' END FROM generate_series(1, 50) g;
ANALYZE topk_desc_many_segs;
EXPLAIN (COSTS OFF, VERBOSE, TIMING OFF)
SELECT id FROM topk_desc_many_segs WHERE body @@@ 'rare'
ORDER BY paradedb.score(id) DESC LIMIT 20;
                                                                        QUERY PLAN                                                                        
----------------------------------------------------------------------------------------------------------------------------------------------------------
 Limit
   Output: id, (paradedb.score(id))
   ->  Gather Merge
         Output: id, (paradedb.score(id))
         Workers Planned: 2
         ->  Parallel Custom Scan (ParadeDB Base Scan) on public.topk_desc_many_segs
               Output: id, paradedb.score(id)
               Table: topk_desc_many_segs
               Index: topk_desc_many_segs_idx
               Exec Method: TopKScanExecState
               Scores: true
                  TopK Order By: pdb.score() desc
                  TopK Limit: 20
               Tantivy Query: {"with_index":{"query":{"parse_with_field":{"field":"body","query_string":"rare","lenient":null,"conjunction_mode":null}}}}
(14 rows)

-- ============================================================
-- Scenario 3: topk_asc_large_match
--
-- Score-asc cannot Block-WAND-prune (worst-matches-first must score every match), so
-- the cost-model intervention from #4664 does NOT apply to this shape — it's
-- gated to score-DESC TopK with a single score sort key, no window
-- aggregates, and a resolved Tantivy query that uses Block-WAND score pruning
-- (see the `is_score_desc_topk` check in basescan/mod.rs).
--
-- Score-asc TopK uses the general `compute_nworkers` worker-selection path. With
-- `declares_sorted_output = true`, the row-count threshold is bypassed and a
-- parallel path is emitted for segment_count > 1.
--
-- This matches James's benchmark in #4664: `'the' ORDER BY score ASC LIMIT 10`
-- went 427ms serial -> 162ms parallel.
--
-- Expected: PARALLEL.
-- ============================================================
EXPLAIN (COSTS OFF, VERBOSE, TIMING OFF)
SELECT id FROM topk_desc_large WHERE body @@@ 'gamma'
ORDER BY paradedb.score(id) ASC LIMIT 10;
                                                                        QUERY PLAN                                                                         
-----------------------------------------------------------------------------------------------------------------------------------------------------------
 Limit
   Output: id, (paradedb.score(id))
   ->  Gather Merge
         Output: id, (paradedb.score(id))
         Workers Planned: 2
         ->  Parallel Custom Scan (ParadeDB Base Scan) on public.topk_desc_large
               Output: id, paradedb.score(id)
               Table: topk_desc_large
               Index: topk_desc_large_idx
               Exec Method: TopKScanExecState
               Scores: true
                  TopK Order By: pdb.score() asc
                  TopK Limit: 10
               Tantivy Query: {"with_index":{"query":{"parse_with_field":{"field":"body","query_string":"gamma","lenient":null,"conjunction_mode":null}}}}
(14 rows)

-- ============================================================
-- Scenario 4: topk_asc_small_match
--
-- Score-asc on few matches. Not enough work for parallel.
-- Expected: SERIAL.
-- ============================================================
DROP TABLE IF EXISTS topk_asc_small CASCADE;
CREATE TABLE topk_asc_small (id INTEGER GENERATED ALWAYS AS IDENTITY PRIMARY KEY, body TEXT NOT NULL);
CREATE INDEX topk_asc_small_idx ON topk_asc_small USING bm25 (id, body)
    WITH (key_field = 'id', target_segment_count = 4,
          layer_sizes = '10TB', background_layer_sizes = '10TB');
INSERT INTO topk_asc_small (body) SELECT 'common word' FROM generate_series(1, 1000);
INSERT INTO topk_asc_small (body) SELECT 'special token' FROM generate_series(1, 5);
ANALYZE topk_asc_small;
EXPLAIN (COSTS OFF, VERBOSE, TIMING OFF)
SELECT id FROM topk_asc_small WHERE body @@@ 'special'
ORDER BY paradedb.score(id) ASC LIMIT 10;
                                                                      QUERY PLAN                                                                       
-------------------------------------------------------------------------------------------------------------------------------------------------------
 Limit
   Output: id, (paradedb.score(id))
   ->  Custom Scan (ParadeDB Base Scan) on public.topk_asc_small
         Output: id, paradedb.score(id)
         Table: topk_asc_small
         Index: topk_asc_small_idx
         Exec Method: TopKScanExecState
         Scores: true
            TopK Order By: pdb.score() asc
            TopK Limit: 10
         Tantivy Query: {"with_index":{"query":{"parse_with_field":{"field":"body","query_string":"special","lenient":null,"conjunction_mode":null}}}}
(11 rows)

-- ============================================================
-- Scenario 5: topk_field_sort_large
--
-- ORDER BY non-score field. Cannot Block-WAND-prune. Same gating as scenario 3:
-- the cost-model intervention is scoped to score-DESC TopK only, so this
-- shape uses the general `compute_nworkers` worker-selection path and emits a
-- parallel path when segment_count > 1.
--
-- Expected: PARALLEL (same handling as scenario 3).
-- ============================================================
EXPLAIN (COSTS OFF, VERBOSE, TIMING OFF)
SELECT id FROM topk_desc_large WHERE body @@@ 'gamma'
ORDER BY id ASC LIMIT 10;
                                                                        QUERY PLAN                                                                         
-----------------------------------------------------------------------------------------------------------------------------------------------------------
 Limit
   Output: id
   ->  Gather Merge
         Output: id
         Workers Planned: 2
         ->  Parallel Custom Scan (ParadeDB Base Scan) on public.topk_desc_large
               Output: id
               Table: topk_desc_large
               Index: topk_desc_large_idx
               Exec Method: TopKScanExecState
               Scores: false
                  TopK Order By: id asc
                  TopK Limit: 10
               Tantivy Query: {"with_index":{"query":{"parse_with_field":{"field":"body","query_string":"gamma","lenient":null,"conjunction_mode":null}}}}
(14 rows)

-- ============================================================
