 Test 2: TopN Join with LIMIT 2 - Should process minimal combinations
(1 row)

SELECT b.title, a.name
FROM books_phase1 b 
JOIN authors_phase1 a ON b.author_id = a.id 
WHERE b.content @@@ 'science' 
  AND a.bio @@@ 'science fiction'
ORDER BY b.id DESC 
LIMIT 2;
